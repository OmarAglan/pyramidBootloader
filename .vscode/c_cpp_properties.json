{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/gnu-efi/inc/**",
                "${workspaceFolder}/gnu-efi/inc/x86_64/**",
                "${workspaceFolder}/gnu-efi/inc/protocol/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "GNU_EFI_USE_MS_ABI",
                "__x86_64__"
            ],
            "windowsSdkVersion": "10.0.22621.0",
            "compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/gnu-efi/inc",
                    "${workspaceFolder}/gnu-efi/inc/x86_64",
                    "${workspaceFolder}/gnu-efi/inc/protocol"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}